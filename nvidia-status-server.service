[Unit]
Description=NVIDIA Status API for Homepage Dashboard
After=network-online.target
Wants=network-online.target

[Service]
User=root
Group=root
Type=simple
EnvironmentFile=/etc/nvidia-status-server.env
ExecStart=/usr/bin/python3 -m gunicorn -w 1 -b 0.0.0.0:8787 server:app
WorkingDirectory=/opt/nvidia-status-server
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target